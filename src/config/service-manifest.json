{
  "serviceMappings": {
    "cache": {
      "name": "缓存服务",
      "icon": "💾",
      "description": "多层缓存服务，支持L1/L2/L3缓存",
      "configKeys": [
        "CACHE_PROVIDERS",
        "PRIMARY_CACHE_PROVIDER", 
        "CACHE_L3_ENABLED",
        "CACHE_L3_DIR",
        "CACHE_BLOOM_FILTER",
        "REDIS_URL",
        "NF_REDIS_URL",
        "REDIS_TOKEN",
        "UPSTASH_REDIS_REST_TOKEN",
        "UPSTASH_REDIS_REST_URL",
        "CLOUDFLARE_KV_ACCOUNT_ID",
        "CLOUDFLARE_ACCOUNT_ID",
        "CLOUDFLARE_KV_NAMESPACE_ID",
        "CLOUDFLARE_KV_TOKEN",
        "REDIS_TLS_ENABLED",
        "NF_REDIS_TLS_ENABLED"
      ],
      "reinitializationStrategy": {
        "type": "destroy_initialize",
        "graceful": true,
        "timeout": 30000
      }
    },
    "telegram": {
      "name": "Telegram服务",
      "icon": "📱",
      "description": "Telegram客户端管理，消息处理",
      "configKeys": [
        "API_ID",
        "API_HASH",
        "BOT_TOKEN",
        "TG_PROXY_HOST",
        "TG_PROXY_PORT",
        "TG_PROXY_TYPE",
        "TG_PROXY_USERNAME",
        "TG_PROXY_PASSWORD",
        "TELEGRAM_PROXY_HOST",
        "TELEGRAM_PROXY_PORT",
        "TELEGRAM_PROXY_TYPE",
        "TELEGRAM_PROXY_USERNAME",
        "TELEGRAM_PROXY_PASSWORD",
        "TG_DEVICE_MODEL",
        "TG_SYSTEM_VERSION",
        "TG_APP_VERSION",
        "TG_SERVER_DC",
        "TG_SERVER_IP",
        "TG_SERVER_PORT",
        "TG_TEST_MODE"
      ],
      "reinitializationStrategy": {
        "type": "lightweight_reconnect",
        "graceful": true,
        "timeout": 60000
      }
    },
    "queue": {
      "name": "队列服务",
      "icon": "📬",
      "description": "消息队列管理",
      "configKeys": [
        "QSTASH_TOKEN",
        "QSTASH_AUTH_TOKEN",
        "QSTASH_URL",
        "QSTASH_CURRENT_SIGNING_KEY",
        "QSTASH_NEXT_SIGNING_KEY",
        "LB_WEBHOOK_URL"
        ,
        "QSTASH_DEBUG",
        "QSTASH_FORCE_DIRECT",
        "BATCH_SIZE",
        "BATCH_TIMEOUT",
        "QSTASH_BATCH_SIZE",
        "QSTASH_BATCH_TIMEOUT",
        "QSTASH_MAX_BUFFER_SIZE",
        "QSTASH_PROCESSED_MESSAGES_LIMIT",
        "QUEUE_USE_IDEMPOTENCY",
        "QUEUE_IDEMPOTENCY_TTL",
        "QUEUE_LOCAL_IDEMPOTENCY_LIMIT",
        "QSTASH_DLQ_SIZE",
        "QSTASH_DLQ_TTL_SECONDS",
        "QSTASH_MAX_CONCURRENT",
        "QSTASH_MOCK_DELAY",
        "QSTASH_MOCK_ERROR",
        "QSTASH_RATE_LIMIT",
        "QSTASH_RATE_WINDOW",
        "QSTASH_ADAPTIVE_RATE",
        "QSTASH_MIN_RATE",
        "QSTASH_MAX_RATE",
        "CALLER_TRACKING_MODE"
      ],
      "reinitializationStrategy": {
        "type": "destroy_initialize",
        "graceful": true,
        "timeout": 15000
      }
      ,
      "behaviorNotes": [
        "QSTASH_DEBUG=true 会记录更多 publish/buffer/debug 信息，帮助判断 QStash 是否真的收到任务",
        "缺失 LB_WEBHOOK_URL 会记录警告并默认使用占位地址，避免消息被发送到未配置的 webhook",
        "QSTASH_FORCE_DIRECT=true 可在诊断时跳过缓冲区，强制立刻发送消息"
      ]
    },
    "logger": {
      "name": "日志服务",
      "icon": "📝",
      "description": "统一日志服务",
      "configKeys": [
        "AXIOM_TOKEN",
        "AXIOM_ORG_ID",
        "AXIOM_DATASET",
        "DATADOG_API_KEY",
        "NEW_RELIC_LICENSE_KEY",
        "NEW_RELIC_REGION",
        "NEW_RELIC_APP_NAME",
        "OTEL_TRACES_SAMPLER",
        "OTEL_TRACES_SAMPLER_ARG",
        "OTEL_SERVICE_NAME",
        "OTEL_RESOURCE_ATTRIBUTES",
        "OTEL_EXPORTER_OTLP_METRICS_TEMPORALITY_PREFERENCE",
        "LOG_LEVEL",
        "MESSAGE_SLOW_WARN_THRESHOLD_MS"
      ],
      "reinitializationStrategy": {
        "type": "reconfigure",
        "graceful": true,
        "timeout": 5000
      }
    },
    "oss": {
      "name": "对象存储服务",
      "icon": "☁️",
      "description": "对象存储服务",
      "configKeys": [
        "R2_ENDPOINT",
        "R2_ACCESS_KEY_ID",
        "R2_SECRET_ACCESS_KEY",
        "R2_BUCKET",
        "R2_PUBLIC_URL",
        "OSS_WORKER_URL",
        "R2_WORKER_URL",
        "OSS_WORKER_SECRET",
        "R2_WORKER_AUTH_TOKEN",
        "OSS_WORKER_UPLOAD_MAX_BUFFER_BYTES"
      ],
      "reinitializationStrategy": {
        "type": "reconfigure",
        "graceful": true,
        "timeout": 10000
      }
    },
    "d1": {
      "name": "D1数据库服务",
      "icon": "🗄️",
      "description": "Cloudflare D1数据库",
      "configKeys": [
        "CLOUDFLARE_D1_DATABASE_ID",
        "CF_D1_DATABASE_ID",
        "CLOUDFLARE_D1_ACCOUNT_ID",
        "CF_D1_ACCOUNT_ID",
        "CLOUDFLARE_D1_TOKEN",
        "CF_D1_TOKEN",
        "CLOUDFLARE_ACCOUNT_ID",
        "CF_ACCOUNT_ID",
        "DB_SCHEMA_CHECK",
        "DB_AUTO_MIGRATE",
        "DB_MIGRATION_LOCK_TTL_MS",
        "DB_MIGRATION_LOCK_WAIT_MS",
        "DB_SCHEMA_READY_RETRY_ATTEMPTS",
        "DB_SCHEMA_READY_RETRY_INITIAL_DELAY_MS",
        "DB_SCHEMA_READY_RETRY_MAX_DELAY_MS"
      ],
      "reinitializationStrategy": {
        "type": "reconnect",
        "graceful": true,
        "timeout": 8000
      }
    },
    "instanceCoordinator": {
      "name": "实例协调器",
      "icon": "🏗️",
      "description": "多实例协调，分布式锁",
      "configKeys": [
        "INSTANCE_ID",
        "HOSTNAME",
        "INSTANCE_REGION"
      ],
      "reinitializationStrategy": {
        "type": "restart",
        "graceful": true,
        "timeout": 20000
      }
      ,
      "behaviorNotes": [
        "DistributedLock 清理过期锁时会容忍非法 expiresAt，并以 unknown 标记日志，防止 toISOString 抛错",
        "新增 _coerceTimestampMs/_safeToISOString 让历史/异常锁仍能正确被判断为过期"
      ]
    },
    "streamForwarding": {
      "name": "流式转发服务",
      "icon": "🔀",
      "description": "跨实例流式转发和断点续传上传",
      "configKeys": [
        "STREAM_FORWARDING_ENABLED",
        "INSTANCE_SECRET",
        "APP_EXTERNAL_URL",
        "STREAM_RESUME_DIR",
        "STREAM_FINALIZATION_TIMEOUT_MS",
        "STREAM_FINALIZATION_POLL_MS"
      ],
      "reinitializationStrategy": {
        "type": "restart",
        "graceful": true,
        "timeout": 20000
      },
      "behaviorNotes": [
        "STREAM_FORWARDING_ENABLED=true 时必须配置非空 INSTANCE_SECRET，否则跨实例流式接口会 fail closed",
        "STREAM_RESUME_DIR 保存断点续传 .part 文件，最终 copyto 成功后由 worker 清理",
        "STREAM_FINALIZATION_* 控制 leader 等待 worker 最终化的超时和轮询间隔"
      ]
    },
    "localStorage": {
      "name": "本地暂存服务",
      "icon": "💽",
      "description": "下载目录和断点续传暂存空间保护",
      "configKeys": [
        "DOWNLOAD_DIR",
        "LOCAL_STORAGE_REQUIRED_HEADROOM_RATIO",
        "LOCAL_STORAGE_REQUIRED_HEADROOM_BYTES"
      ],
      "reinitializationStrategy": {
        "type": "restart",
        "graceful": true,
        "timeout": 20000
      },
      "behaviorNotes": [
        "本地文件暂存前会校验目录可写和剩余空间，避免大文件半路写爆磁盘",
        "LOCAL_STORAGE_REQUIRED_HEADROOM_* 同时保护 Telegram 下载、外部链接下载和流式断点续传 staging"
      ]
    },
    "directTransfer": {
      "name": "直传服务",
      "icon": "📤",
      "description": "普通 Telegram 文件同机直传，优先 rclone rcat；可配置为严格零落盘",
      "configKeys": [
        "DIRECT_TRANSFER_ENABLED",
        "DIRECT_TRANSFER_FALLBACK_TO_LOCAL",
        "DIRECT_TRANSFER_TIMEOUT_MS",
        "DIRECT_TRANSFER_MAX_ATTEMPTS",
        "DIRECT_TRANSFER_RETRY_DELAY_MS"
      ],
      "reinitializationStrategy": {
        "type": "none",
        "graceful": true,
        "timeout": 0
      },
      "behaviorNotes": [
        "DIRECT_TRANSFER_ENABLED=false 会完全关闭同机无盘直传，保留原本完整落盘转存路径",
        "DIRECT_TRANSFER_FALLBACK_TO_LOCAL=true 时，rcat/moveto/远端校验失败会清理远端暂存并回退到本地暂存",
        "DIRECT_TRANSFER_FALLBACK_TO_LOCAL=false 是严格零落盘模式：能力不支持、远端冲突或直传失败都会 fail closed，不进入本地缓存/下载/上传链路",
        "DIRECT_TRANSFER_TIMEOUT_MS 控制单次 rcat 直传最长运行时间，避免子进程挂死导致任务长期卡住",
        "DIRECT_TRANSFER_MAX_ATTEMPTS / DIRECT_TRANSFER_RETRY_DELAY_MS 控制零落盘直传遇到可重试错误时的重试预算，耗尽后才按 fallback 策略处理",
        "直传只复用 rclone 支持的流式能力；OSS/R2 的 multipart stream 未收口前必须使用 fallback=true 才会走本地暂存"
      ]
    },
    "externalDownload": {
      "name": "外部链接离线下载",
      "icon": "🌐",
      "description": "管理员可用的 HTTP/HTTPS 外部链接离线下载入口",
      "configKeys": [
        "EXTERNAL_DOWNLOAD_MAX_BYTES",
        "EXTERNAL_DOWNLOAD_TIMEOUT_MS",
        "EXTERNAL_DOWNLOAD_MAX_REDIRECTS"
      ],
      "reinitializationStrategy": {
        "type": "restart",
        "graceful": true,
        "timeout": 20000
      },
      "behaviorNotes": [
        "仅支持 HTTP/HTTPS，P2P、FTP、file/data 等协议会 fail closed",
        "下载前会做 SSRF 防护并限制重定向次数",
        "文件以流式方式写入临时 .part 文件，完成后原子重命名",
        "落盘前复用 localStorage 守卫校验下载目录可写和剩余空间"
      ]
    }
  },
  "criticalServices": [
    "cache",
    "telegram", 
    "queue"
  ],
  "healthChecks": {
    "cache": {
      "method": "ping",
      "timeout": 5000,
      "expectedResult": true
    },
    "telegram": {
      "method": "getConnectionStatus",
      "timeout": 10000,
      "expectedResult": { "connected": true }
    },
    "queue": {
      "method": "getCircuitBreakerStatus",
      "timeout": 5000,
      "expectedResult": { "state": "closed" }
    }
  },
  "logging": {
    "enabled": true,
    "level": "info",
    "showDetails": true,
    "showSummary": true,
    "showAffectedServices": true,
    "showReinitializationProgress": true,
    "showHealthCheckResults": true,
    "emoji": {
      "enabled": true,
      "separator": "🔮",
      "success": "✅",
      "warning": "⚠️",
      "error": "❌",
      "info": "📊",
      "progress": "🔄"
    }
  },
  "performance": {
    "parallelReinitialization": true,
    "maxConcurrentServices": 10,
    "healthCheckTimeout": 15000,
    "reinitializationTimeout": 60000
  },
  "errorHandling": {
    "continueOnFailure": true,
    "maxRetries": 3,
    "retryDelay": 1000,
    "logFailures": true,
    "alertOnCriticalFailure": true
  }
}
