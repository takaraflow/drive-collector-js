# ============================================
# Telegram Bot Configuration
# ============================================
# Required for Telegram bot functionality
API_ID=
API_HASH=
BOT_TOKEN=
OWNER_ID=

# ============================================
# Rclone Configuration
# ============================================
# Required for cloud storage operations
RCLONE_REMOTE=
REMOTE_FOLDER=
RCLONE_CONF_BASE64=

# ============================================
# QStash Configuration
# ============================================
# Required for message queue and webhook processing
# QSTASH_AUTH_TOKEN: Used for publishing messages (starts with 'authorization_')
# QSTASH_CURRENT_SIGNING_KEY: Used for verifying webhooks (starts with 'sig_')
QSTASH_AUTH_TOKEN=
QSTASH_TOKEN=
QSTASH_CURRENT_SIGNING_KEY=
QSTASH_NEXT_SIGNING_KEY=
QSTASH_URL=
LB_WEBHOOK_URL=

# QStash Optimization - Batch Processing
# Batch size for QStash message aggregation (default: 10)
QSTASH_BATCH_SIZE=10
# Batch timeout in milliseconds (default: 100)
QSTASH_BATCH_TIMEOUT=100
# Maximum concurrent QStash requests (default: 5)
QSTASH_MAX_CONCURRENT=5
# Base rate limit for QStash API (default: 5)
QSTASH_RATE_LIMIT=5
# Rate limit window in milliseconds (default: 60000)
QSTASH_RATE_WINDOW=60000
# Enable adaptive rate limiting (default: true)
QSTASH_ADAPTIVE_RATE=true
# Minimum rate limit for adaptive control (default: 3)
QSTASH_MIN_RATE=3
# Maximum rate limit for adaptive control (default: 10)
QSTASH_MAX_RATE=10

# ============================================
# Stream Forwarding Configuration
# ============================================
STREAM_FORWARDING_ENABLED=false
INSTANCE_SECRET=
APP_EXTERNAL_URL=
STREAM_RESUME_DIR=
STREAM_FINALIZATION_TIMEOUT_MS=21600000
STREAM_FINALIZATION_POLL_MS=3000

# ============================================
# Same-worker Direct Transfer Configuration
# ============================================
DIRECT_TRANSFER_ENABLED=true
# true = preferred direct transfer; false = strict zero-disk mode that fails instead of local staging
DIRECT_TRANSFER_FALLBACK_TO_LOCAL=true
DIRECT_TRANSFER_TIMEOUT_MS=21600000

# ============================================
# External Offline Download Configuration
# ============================================
EXTERNAL_DOWNLOAD_MAX_BYTES=5368709120
EXTERNAL_DOWNLOAD_TIMEOUT_MS=30000
EXTERNAL_DOWNLOAD_MAX_REDIRECTS=5

# ============================================
# OSS Worker Configuration
# ============================================
# Optional: For object storage operations
OSS_WORKER_URL=
OSS_WORKER_SECRET=

# ============================================
# Cloudflare R2 Configuration
# ============================================
# Optional: For R2 storage backend
R2_ENDPOINT=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=
R2_PUBLIC_URL=

# ============================================
# Axiom Configuration
# ============================================
# Optional: For logging and observability
AXIOM_TOKEN=
AXIOM_ORG_ID=
AXIOM_DATASET=

# ============================================
# Cloudflare D1 / Database Schema
# ============================================
CLOUDFLARE_D1_ACCOUNT_ID=
CLOUDFLARE_D1_DATABASE_ID=
CLOUDFLARE_D1_TOKEN=
# Startup checks schema version by default. Disable only for emergency diagnostics.
DB_SCHEMA_CHECK=true
# Explicit opt-in: run pending migrations during startup instead of only checking.
DB_AUTO_MIGRATE=false
DB_MIGRATION_LOCK_TTL_MS=120000
DB_MIGRATION_LOCK_WAIT_MS=30000

# ============================================
# Redis Configuration
# ============================================
# Primary Redis connection URL (TLS/SNI enabled)
# Format: rediss://username:password@host:port
# Example: rediss://user:password@master.drive-collector-redis--qmnl9h54d875.addon.code.run:6379
REDIS_URL=

# Alternative: Individual connection parameters
REDIS_HOST=
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_TOKEN=

# Northflank Redis Configuration (NF_ Prefix) - Legacy support
NF_REDIS_URL=
NF_REDIS_HOST=
NF_REDIS_PORT=6379
NF_REDIS_PASSWORD=

# ============================================
# Cloudflare Cache Configuration
# ============================================
# Required for distributed key-value storage
# Used for: caching, rate limiting, instance coordination
# Supports both CF_CACHE_* (new) and CF_KV_* (legacy) variables
CF_CACHE_ACCOUNT_ID=
CF_CACHE_NAMESPACE_ID=
CF_CACHE_TOKEN=

# Legacy Cloudflare KV variables (deprecated, use CF_CACHE_* above)
CF_KV_ACCOUNT_ID=
CF_KV_NAMESPACE_ID=
CF_KV_TOKEN=

# ============================================
# Upstash Redis Configuration
# ============================================
# Required for Redis operations via REST API
# Used for: caching, session management, task queue
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# ============================================
# Cache Feature Flags
# ============================================
# Optional persistent local L3 cache. Redis remains the preferred shared cache.
CACHE_L3_ENABLED=false
CACHE_L3_DIR=./data/cache/l3
CACHE_BLOOM_FILTER=false

# ============================================
# Telegram Proxy Configuration
# ============================================
# Optional: For Telegram connection through proxy
TELEGRAM_PROXY_HOST=
TELEGRAM_PROXY_PORT=
TELEGRAM_PROXY_TYPE=
TELEGRAM_PROXY_USERNAME=
TELEGRAM_PROXY_PASSWORD=

# ============================================
# Telegram Advanced Configuration
# ============================================
TG_DEVICE_MODEL=
TG_SYSTEM_VERSION=
TG_APP_VERSION=
TG_TEST_MODE=false # 设置为 true 以连接 Telegram 测试服务器。如果未设置，在 dev 模式 (npm run dev) 下默认为 true。
TG_SERVER_DC=
TG_SERVER_IP=
TG_SERVER_PORT=

# ============================================
# Redis TLS Configuration
# ============================================
# Optional: For custom TLS settings
REDIS_TLS_ENABLED=false
NF_REDIS_TLS_ENABLED=false
REDIS_TLS_REJECT_UNAUTHORIZED=true
NF_REDIS_TLS_REJECT_UNAUTHORIZED=true
REDIS_TLS_CA=
NF_REDIS_TLS_CA=
REDIS_TLS_CLIENT_CERT=
NF_REDIS_TLS_CLIENT_CERT=
REDIS_TLS_CLIENT_KEY=
NF_REDIS_TLS_CLIENT_KEY=
REDIS_SNI_SERVERNAME=
NF_REDIS_SNI_SERVERNAME=

# ============================================
# Redis Connection Optimization
# ============================================
# Optional: Connection pool and retry settings
REDIS_CONNECT_TIMEOUT=15000
REDIS_KEEP_ALIVE=30000
REDIS_LAZY_CONNECT=true
REDIS_ENABLE_READY_CHECK=true
REDIS_MAX_RETRIES_PER_REQUEST=5
REDIS_ENABLE_AUTO_PIPELINING=true
REDIS_MAX_RETRIES=5
REDIS_RETRY_BASE_DELAY=500
REDIS_RETRY_MAX_DELAY=30000

# ============================================
# Infisical Configuration
# ============================================
# Runtime load and scripts/sync-env.js fetch Infisical secrets into process.env.
# Remote secrets are not written to disk by default.
#
# File write policy:
# - Default and production behavior: never write remote secrets to .env files.
# - Local development escape hatch only: all of these must be true:
#   NODE_ENV resolves to dev
#   INFISICAL_ENV is empty or resolves to dev
#   SYNC_ENV_WRITE_FILE=true
#   ALLOW_SECRET_FILE_WRITE=true
# - prod/pre/test reject file writes immediately, even when both flags are set.
#
# Fallback chain:
# 1. Infisical SDK when INFISICAL_TOKEN and INFISICAL_PROJECT_ID are present.
# 2. Existing local .env/.env.<env> only as an input fallback.
# 3. Current process.env.
#
# STRICT_SYNC=1 makes missing credentials, failed Infisical fetches, or missing
# required manifest variables fatal. STRICT_SYNC=0 allows fallback checks.
#
# Environment priority: INFISICAL_ENV > NODE_ENV > dev.
# Supported names: dev/pre/prod plus development/production/staging aliases.
INFISICAL_TOKEN=
INFISICAL_PROJECT_ID=
NODE_ENV=prod
INFISICAL_ENV=prod
INFISICAL_SECRET_PATH=/
STRICT_SYNC=1
SYNC_ENV_WRITE_FILE=false
ALLOW_SECRET_FILE_WRITE=false
MESSAGE_SLOW_WARN_THRESHOLD_MS=2000

# ============================================
# Worker Configuration
# ============================================
# Optional: Server port for webhooks
PORT=
